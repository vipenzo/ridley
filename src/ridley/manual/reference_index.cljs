    :path "docs/manual/reference/en/path-length.md"}

   "path-to"
   {:name "path-to"
    :category "path"
    :status "stable"
    :since ""
    :signature "(path-to anchor-name)"
    :description "Build a path from the turtle's current position to a named anchor, returning a path map. Two things happen:"
